<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم المركزية</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header class="header">
        <div class="header-content">
            <h1>🎛️ لوحة التحكم المركزية</h1>
            <div class="time-date">
                <span id="current-time">00:00:00</span>
                <span id="current-date">التاريخ</span>
            </div>
        </div>
    </header>

    <!-- المحتوى الرئيسي -->
    <div class="container">
        <!-- الشريط الجانبي -->
        <aside class="sidebar">
            <nav class="nav-menu">
                <div class="nav-item active" data-section="dashboard">
                    <span class="icon">📊</span>
                    <span class="text">لوحة البيانات</span>
                </div>
                <div class="nav-item" data-section="controls">
                    <span class="icon">⚙️</span>
                    <span class="text">التحكم</span>
                </div>
                <div class="nav-item" data-section="monitoring">
                    <span class="icon">📡</span>
                    <span class="text">المراقبة</span>
                </div>
                <div class="nav-item" data-section="settings">
                    <span class="icon">⚡</span>
                    <span class="text">الإعدادات</span>
                </div>
                <div class="nav-item" data-section="reports">
                    <span class="icon">📈</span>
                    <span class="text">التقارير</span>
                </div>
            </nav>
        </aside>

        <!-- المحتوى الرئيسي -->
        <main class="content">
            <!-- قسم لوحة البيانات -->
            <section id="dashboard" class="section active">
                <h2>📊 لوحة البيانات</h2>
                
                <!-- الإحصائيات السريعة -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">👥</div>
                        <div class="stat-info">
                            <div class="stat-label">المستخدمون النشطون</div>
                            <div class="stat-value">1,234</div>
                            <div class="stat-change positive">↑ 12% من الأمس</div>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon">💰</div>
                        <div class="stat-info">
                            <div class="stat-label">الإيرادات</div>
                            <div class="stat-value">$45,320</div>
                            <div class="stat-change positive">↑ 8% من الشهر</div>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon">📦</div>
                        <div class="stat-info">
                            <div class="stat-label">الطلبات الجديدة</div>
                            <div class="stat-value">567</div>
                            <div class="stat-change negative">↓ 3% من الأمس</div>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon">⭐</div>
                        <div class="stat-info">
                            <div class="stat-label">رضا العملاء</div>
                            <div class="stat-value">4.8/5</div>
                            <div class="stat-change positive">↑ 0.5 من الشهر</div>
                        </div>
                    </div>
                </div>

                <!-- الرسوم البيانية -->
                <div class="charts-grid">
                    <div class="chart-card">
                        <h3>📈 أداء النظام</h3>
                        <div class="performance-bars">
                            <div class="bar-item">
                                <div class="bar-label">الخادم 1</div>
                                <div class="bar-container">
                                    <div class="bar-fill" style="width: 85%"></div>
                                </div>
                                <div class="bar-value">85%</div>
                            </div>
                            <div class="bar-item">
                                <div class="bar-label">الخادم 2</div>
                                <div class="bar-container">
                                    <div class="bar-fill" style="width: 72%"></div>
                                </div>
                                <div class="bar-value">72%</div>
                            </div>
                            <div class="bar-item">
                                <div class="bar-label">الخادم 3</div>
                                <div class="bar-container">
                                    <div class="bar-fill" style="width: 91%"></div>
                                </div>
                                <div class="bar-value">91%</div>
                            </div>
                            <div class="bar-item">
                                <div class="bar-label">الخادم 4</div>
                                <div class="bar-container">
                                    <div class="bar-fill" style="width: 68%"></div>
                                </div>
                                <div class="bar-value">68%</div>
                            </div>
                        </div>
                    </div>

                    <div class="chart-card">
                        <h3>⚙️ حالة الأنظمة</h3>
                        <div class="status-list">
                            <div class="status-item">
                                <span class="status-dot active"></span>
                                <span class="status-name">قاعدة البيانات</span>
                                <span class="status-text">نشطة</span>
                            </div>
                            <div class="status-item">
                                <span class="status-dot active"></span>
                                <span class="status-name">خادم الويب</span>
                                <span class="status-text">نشط</span>
                            </div>
                            <div class="status-item">
                                <span class="status-dot inactive"></span>
                                <span class="status-name">خادم النسخ الاحتياطي</span>
                                <span class="status-text">معطل</span>
                            </div>
                            <div class="status-item">
                                <span class="status-dot warning"></span>
                                <span class="status-name">خادم البريد</span>
                                <span class="status-text">بطيء</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- الأنشطة الأخيرة -->
                <div class="activity-card">
                    <h3>📝 الأنشطة الأخيرة</h3>
                    <div class="activity-list">
                        <div class="activity-item">
                            <div class="activity-time">14:32</div>
                            <div class="activity-content">
                                <div class="activity-title">تسجيل دخول مستخدم جديد</div>
                                <div class="activity-description">المستخدم: admin@example.com</div>
                            </div>
                            <div class="activity-badge new">جديد</div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-time">14:15</div>
                            <div class="activity-content">
                                <div class="activity-title">تحديث نظام</div>
                                <div class="activity-description">تم تحديث النظام بنجاح</div>
                            </div>
                            <div class="activity-badge success">مكتمل</div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-time">13:45</div>
                            <div class="activity-content">
                                <div class="activity-title">خطأ في الخادم</div>
                                <div class="activity-description">حدث خطأ في الخادم 2 ثم تم حله</div>
                            </div>
                            <div class="activity-badge error">خطأ</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- قسم التحكم -->
            <section id="controls" class="section">
                <h2>⚙️ لوحة التحكم</h2>
                
                <div class="controls-grid">
                    <!-- مجموعة التحكم 1 -->
                    <div class="control-group">
                        <h3>🎚️ التحكم بالسرعة</h3>
                        <div class="control-item">
                            <label for="speed-slider">السرعة:</label>
                            <div class="slider-container">
                                <input type="range" id="speed-slider" class="slider" min="0" max="100" value="50">
                                <span class="slider-value" id="speed-value">50%</span>
                            </div>
                            <div class="slider-markers">
                                <span>0</span>
                                <span>25</span>
                                <span>50</span>
                                <span>75</span>
                                <span>100</span>
                            </div>
                        </div>

                        <div class="control-item">
                            <label for="temperature-slider">درجة الحرارة:</label>
                            <div class="slider-container">
                                <input type="range" id="temperature-slider" class="slider" min="16" max="30" value="22">
                                <span class="slider-value" id="temperature-value">22°C</span>
                            </div>
                        </div>
                    </div>

                    <!-- مجموعة التحكم 2 -->
                    <div class="control-group">
                        <h3>🔘 عناصر التحكم</h3>
                        <div class="button-group">
                            <button class="btn btn-success" onclick="toggleDevice('device1')">
                                <span class="btn-icon">💡</span>
                                <span class="btn-text">إضاءة المكتب</span>
                                <span class="btn-status" id="device1-status">معطلة</span>
                            </button>
                            <button class="btn btn-success" onclick="toggleDevice('device2')">
                                <span class="btn-icon">❄️</span>
                                <span class="btn-text">مكيف الهواء</span>
                                <span class="btn-status" id="device2-status">معطل</span>
                            </button>
                            <button class="btn btn-success" onclick="toggleDevice('device3')">
                                <span class="btn-icon">📺</span>
                                <span class="btn-text">شاشة العرض</span>
                                <span class="btn-status" id="device3-status">معطلة</span>
                            </button>
                            <button class="btn btn-success" onclick="toggleDevice('device4')">
                                <span class="btn-icon">🔊</span>
                                <span class="btn-text">النظام الصوتي</span>
                                <span class="btn-status" id="device4-status">معطل</span>
                            </button>
                        </div>
                    </div>

                    <!-- مجموعة التحكم 3 -->
                    <div class="control-group">
                        <h3>⚡ إجراءات سريعة</h3>
                        <div class="button-group vertical">
                            <button class="btn btn-primary" onclick="performAction('restart')">
                                <span class="btn-icon">🔄</span>
                                <span class="btn-text">إعادة تشغيل النظام</span>
                            </button>
                            <button class="btn btn-warning" onclick="performAction('maintenance')">
                                <span class="btn-icon">🔧</span>
                                <span class="btn-text">وضع الصيانة</span>
                            </button>
                            <button class="btn btn-danger" onclick="performAction('shutdown')">
                                <span class="btn-icon">⛔</span>
                                <span class="btn-text">إيقاف النظام</span>
                            </button>
                        </div>
                    </div>

                    <!-- مجموعة التحكم 4 -->
                    <div class="control-group">
                        <h3>✅ اختيارات متعددة</h3>
                        <div class="checkbox-group">
                            <label class="checkbox-item">
                                <input type="checkbox" checked>
                                <span class="checkbox-label">تفعيل التنبيهات</span>
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox">
                                <span class="checkbox-label">الوضع الآمن</span>
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" checked>
                                <span class="checkbox-label">السجلات التلقائية</span>
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox">
                                <span class="checkbox-label">الإرسال إلى السحابة</span>
                            </label>
                        </div>
                    </div>
                </div>
            </section>

            <!-- قسم المراقبة -->
            <section id="monitoring" class="section">
                <h2>📡 المراقبة المباشرة</h2>
                
                <div class="monitoring-grid">
                    <div class="monitor-card">
                        <h3>⚙️ استخدام المعالج</h3>
                        <div class="gauge">
                            <svg width="200" height="200" viewBox="0 0 200 200">
                                <circle cx="100" cy="100" r="90" fill="none" stroke="#e0e0e0" stroke-width="20"/>
                                <circle cx="100" cy="100" r="90" fill="none" stroke="#4CAF50" stroke-width="20"
                                    stroke-dasharray="282.7" stroke-dashoffset="56.54" stroke-linecap="round"/>
                                <text x="100" y="110" font-size="24" font-weight="bold" text-anchor="middle" fill="#333">80%</text>
                            </svg>
                        </div>
                    </div>

                    <div class="monitor-card">
                        <h3>💾 استخدام الذاكرة</h3>
                        <div class="gauge">
                            <svg width="200" height="200" viewBox="0 0 200 200">
                                <circle cx="100" cy="100" r="90" fill="none" stroke="#e0e0e0" stroke-width="20"/>
                                <circle cx="100" cy="100" r="90" fill="none" stroke="#2196F3" stroke-width="20"
                                    stroke-dasharray="282.7" stroke-dashoffset="84.81" stroke-linecap="round"/>
                                <text x="100" y="110" font-size="24" font-weight="bold" text-anchor="middle" fill="#333">70%</text>
                            </svg>
                        </div>
                    </div>

                    <div class="monitor-card">
                        <h3>💿 استخدام التخزين</h3>
                        <div class="gauge">
                            <svg width="200" height="200" viewBox="0 0 200 200">
                                <circle cx="100" cy="100" r="90" fill="none" stroke="#e0e0e0" stroke-width="20"/>
                                <circle cx="100" cy="100" r="90" fill="none" stroke="#FF9800" stroke-width="20"
                                    stroke-dasharray="282.7" stroke-dashoffset="113.08" stroke-linecap="round"/>
                                <text x="100" y="110" font-size="24" font-weight="bold" text-anchor="middle" fill="#333">60%</text>
                            </svg>
                        </div>
                    </div>

                    <div class="monitor-card">
                        <h3>🌐 استخدام النطاق الترددي</h3>
                        <div class="gauge">
                            <svg width="200" height="200" viewBox="0 0 200 200">
                                <circle cx="100" cy="100" r="90" fill="none" stroke="#e0e0e0" stroke-width="20"/>
                                <circle cx="100" cy="100" r="90" fill="none" stroke="#F44336" stroke-width="20"
                                    stroke-dasharray="282.7" stroke-dashoffset="42.405" stroke-linecap="round"/>
                                <text x="100" y="110" font-size="24" font-weight="bold" text-anchor="middle" fill="#333">85%</text>
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- جدول البيانات المباشرة -->
                <div class="data-table-card">
                    <h3>📊 البيانات المباشرة للأنظمة</h3>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>اسم النظام</th>
                                <th>الحالة</th>
                                <th>وقت التشغيل</th>
                                <th>الأداء</th>
                                <th>درجة الحرارة</th>
                                <th>آخر تحديث</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>خادم الويب</td>
                                <td><span class="status-badge active">✓ نشط</span></td>
                                <td>45 يوم</td>
                                <td>
                                    <div class="mini-bar">
                                        <div class="mini-bar-fill" style="width: 85%"></div>
                                    </div>
                                </td>
                                <td>62°C</td>
                                <td>الآن</td>
                            </tr>
                            <tr>
                                <td>قاعدة البيانات</td>
                                <td><span class="status-badge active">✓ نشط</span></td>
                                <td>120 يوم</td>
                                <td>
                                    <div class="mini-bar">
                                        <div class="mini-bar-fill" style="width: 72%"></div>
                                    </div>
                                </td>
                                <td>58°C</td>
                                <td>الآن</td>
                            </tr>
                            <tr>
                                <td>خادم التطبيقات</td>
                                <td><span class="status-badge active">✓ نشط</span></td>
                                <td>30 يوم</td>
                                <td>
                                    <div class="mini-bar">
                                        <div class="mini-bar-fill" style="width: 91%"></div>
                                    </div>
                                </td>
                                <td>71°C</td>
                                <td>الآن</td>
                            </tr>
                            <tr>
                                <td>خادم النسخ الاحتياطي</td>
                                <td><span class="status-badge inactive">✗ معطل</span></td>
                                <td>--</td>
                                <td>
                                    <div class="mini-bar">
                                        <div class="mini-bar-fill" style="width: 0%"></div>
                                    </div>
                                </td>
                                <td>--</td>
                                <td>قبل 2 ساعة</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- قسم الإعدادات -->
            <section id="settings" class="section">
                <h2>⚡ الإعدادات</h2>
                
                <div class="settings-grid">
                    <div class="settings-card">
                        <h3>🔐 الأمان</h3>
                        <div class="settings-item">
                            <label for="password">تغيير كلمة المرور:</label>
                            <input type="password" id="password" placeholder="أدخل كلمة المرور الجديدة">
                            <button class="btn btn-primary" onclick="saveSettings()">حفظ</button>
                        </div>
                        <div class="settings-item">
                            <label>المصادقة الثنائية:</label>
                            <label class="toggle-switch">
                                <input type="checkbox" checked>
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>

                    <div class="settings-card">
                        <h3>🌍 الإعدادات العامة</h3>
                        <div class="settings-item">
                            <label for="language">اللغة:</label>
                            <select id="language">
                                <option selected>العربية</option>
                                <option>English</option>
                                <option>Français</option>
                            </select>
                        </div>
                        <div class="settings-item">
                            <label for="theme">المظهر:</label>
                            <select id="theme">
                                <option selected>مظهر فاتح</option>
                                <option>مظهر داكن</option>
                                <option>مظهر أزرق</option>
                            </select>
                        </div>
                    </div>

                    <div class="settings-card">
                        <h3>📧 الإشعارات</h3>
                        <div class="settings-item">
                            <label class="checkbox-item">
                                <input type="checkbox" checked>
                                <span class="checkbox-label">إشعارات البريد الإلكتروني</span>
                            </label>
                        </div>
                        <div class="settings-item">
                            <label class="checkbox-item">
                                <input type="checkbox" checked>
                                <span class="checkbox-label">إشعارات SMS</span>
                            </label>
                        </div>
                        <div class="settings-item">
                            <label class="checkbox-item">
                                <input type="checkbox">
                                <span class="checkbox-label">إشعارات الدفع</span>
                            </label>
                        </div>
                    </div>

                    <div class="settings-card">
                        <h3>💾 البيانات</h3>
                        <div class="settings-item">
                            <button class="btn btn-primary" onclick="backupData()">💾 نسخة احتياطية</button>
                            <button class="btn btn-warning" onclick="exportData()" style="margin-right: 10px;">📥 تصدير</button>
                        </div>
                        <div class="settings-item">
                            <button class="btn btn-danger" onclick="if(confirm('هل تريد حقاً مسح جميع البيانات؟')) deleteData()">🗑️ مسح البيانات</button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- قسم التقارير -->
            <section id="reports" class="section">
                <h2>📈 التقارير</h2>
                
                <div class="reports-grid">
                    <div class="report-card">
                        <h3>📊 تقرير الأداء الشهري</h3>
                        <p class="report-date">الفترة: 1 - 30 يوليو 2024</p>
                        <div class="report-items">
                            <div class="report-item">
                                <span class="report-label">متوسط الأداء:</span>
                                <span class="report-value">87.5%</span>
                            </div>
                            <div class="report-item">
                                <span class="report-label">وقت التعطل:</span>
                                <span class="report-value">2.3 ساعة</span>
                            </div>
                            <div class="report-item">
                                <span class="report-label">الطلبات المعالجة:</span>
                                <span class="report-value">125,430</span>
                            </div>
                        </div>
                        <button class="btn btn-primary" onclick="downloadReport('monthly')">📥 تحميل التقرير</button>
                    </div>

                    <div class="report-card">
                        <h3>👥 تقرير نشاط المستخدمين</h3>
                        <p class="report-date">الفترة: 1 - 30 يوليو 2024</p>
                        <div class="report-items">
                            <div class="report-item">
                                <span class="report-label">المستخدمون الجدد:</span>
                                <span class="report-value">342</span>
                            </div>
                            <div class="report-item">
                                <span class="report-label">المستخدمون النشطون:</span>
                                <span class="report-value">1,234</span>
                            </div>
                            <div class="report-item">
                                <span class="report-label">معدل الاحتفاظ:</span>
                                <span class="report-value">92%</span>
                            </div>
                        </div>
                        <button class="btn btn-primary" onclick="downloadReport('users')">📥 تحميل التقرير</button>
                    </div>

                    <div class="report-card">
                        <h3>🐛 تقرير الأخطاء والمشاكل</h3>
                        <p class="report-date">الفترة: 1 - 30 يوليو 2024</p>
                        <div class="report-items">
                            <div class="report-item">
                                <span class="report-label">إجمالي الأخطاء:</span>
                                <span class="report-value">45</span>
                            </div>
                            <div class="report-item">
                                <span class="report-label">الأخطاء الحرجة:</span>
                                <span class="report-value">3</span>
                            </div>
                            <div class="report-item">
                                <span class="report-label">معدل الحل:</span>
                                <span class="report-value">98%</span>
                            </div>
                        </div>
                        <button class="btn btn-primary" onclick="downloadReport('errors')">📥 تحميل التقرير</button>
                    </div>

                    <div class="report-card">
                        <h3>💰 تقرير الإيرادات</h3>
                        <p class="report-date">الفترة: 1 - 30 يوليو 2024</p>
                        <div class="report-items">
                            <div class="report-item">
                                <span class="report-label">إجمالي الإيرادات:</span>
                                <span class="report-value">$125,430</span>
                            </div>
                            <div class="report-item">
                                <span class="report-label">المصاريف:</span>
                                <span class="report-value">$45,200</span>
                            </div>
                            <div class="report-item">
                                <span class="report-label">صافي الربح:</span>
                                <span class="report-value">$80,230</span>
                            </div>
                        </div>
                        <button class="btn btn-primary" onclick="downloadReport('revenue')">📥 تحميل التقرير</button>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="script.js"></script>
</body>
</html>
